{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "EmailVerification": {
    "Enabled": false,
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpUseSsl": false,
    "SmtpUser": "",
    "SmtpPassword": "",
    "FromAddress": "noreply@example.com",
    "FromName": "Varyo CMS",
    "CodeExpiryMinutes": 5,
    "MaxAttempts": 3
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext" ],
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "VaryoCms",
          "tableName": "logs",
          "autoCreateSqlTable": false,
          "restrictedToMinimumLevel": "Warning",
          "columnOptionsSection": {
            "removeStandardColumns": [],
            "additionalColumns": [
              { "ColumnName": "TenantId",    "PropertyName": "TenantId",    "DataType": "int",      "AllowNull": true },
              { "ColumnName": "UserId",      "PropertyName": "UserId",      "DataType": "int",      "AllowNull": true },
              { "ColumnName": "Role",        "PropertyName": "Role",        "DataType": "nvarchar", "DataLength": 50,  "AllowNull": true },
              { "ColumnName": "RequestPath", "PropertyName": "RequestPath", "DataType": "nvarchar", "DataLength": 500, "AllowNull": true }
            ]
          }
        }
      }
      /* Graylog: add the block below in appsettings.Production.json (or here) to enable GELF output.
         No code change needed — Serilog reads WriteTo at startup.
      ,{
        "Name": "Graylog",
        "Args": {
          "hostnameOrAddress": "graylog.internal",
          "port": 12201,
          "transportType": "Udp"
        }
      }
      */
    ]
  }
}
