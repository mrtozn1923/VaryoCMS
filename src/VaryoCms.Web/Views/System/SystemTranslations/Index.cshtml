@model SystemTranslationListDto
@{
    ViewData["Title"] = L["Translation.Title"].Value;
    var active = Model.Cultures.Where(c => c.IsActive).ToList();
}

@if (TempData["Msg"] is string msg)
{
    <div class="cms-alert-success mb-3"><i class="bi bi-check-circle-fill"></i><span>@msg</span></div>
}
@if (TempData["Error"] is string err)
{
    <div class="cms-alert-danger mb-3"><i class="bi bi-exclamation-triangle-fill"></i><span>@err</span></div>
}

<div class="row g-4 mb-4">
    <div class="col-lg-6">
        <div class="card cms-card h-100">
            <div class="card-header cms-card-header"><h5 class="card-title mb-0">@L["Translation.Languages"]</h5></div>
            <div class="card-body">
                <div class="d-flex flex-wrap gap-2 mb-3">
                    @foreach (var c in Model.Cultures)
                    {
                        <span class="badge @(c.IsActive ? "cms-badge-success" : "cms-badge-secondary")">
                            @c.Code.ToUpper() · @c.Name@(c.IsDefault ? " ★" : "")
                        </span>
                    }
                </div>
                <form method="post" asp-action="AddCulture" class="d-flex flex-wrap gap-2 align-items-end">
                    @Html.AntiForgeryToken()
                    <div>
                        <label class="cms-label">@L["Common.Code"]</label>
                        <input name="code" class="form-control slug-field" placeholder="de" maxlength="5" style="width:90px" />
                    </div>
                    <div class="flex-grow-1">
                        <label class="cms-label">@L["Common.Name"]</label>
                        <input name="name" class="form-control" placeholder="Deutsch" />
                    </div>
                    <button type="submit" class="btn cms-btn-primary"><i class="bi bi-plus-lg me-1"></i>@L["Translation.AddLanguage"]</button>
                </form>
            </div>
        </div>
    </div>
    <div class="col-lg-6">
        <div class="card cms-card h-100">
            <div class="card-header cms-card-header"><h5 class="card-title mb-0">@L["Translation.ImportExport"]</h5></div>
            <div class="card-body">
                <form method="post" asp-action="Import">
                    @Html.AntiForgeryToken()
                    <div class="d-flex gap-2 align-items-end mb-2">
                        <div>
                            <label class="cms-label">@L["Common.Code"]</label>
                            <select name="culture" class="form-select" style="width:120px">
                                @foreach (var c in active)
                                {
                                    <option value="@c.Code">@c.Code.ToUpper()</option>
                                }
                            </select>
                        </div>
                        <button type="submit" class="btn cms-btn-primary"><i class="bi bi-upload me-1"></i>@L["Translation.Import"]</button>
                        @foreach (var c in active)
                        {
                            <a class="btn btn-outline-secondary" asp-action="Export" asp-route-culture="@c.Code">
                                <i class="bi bi-download me-1"></i>@c.Code.ToUpper()
                            </a>
                        }
                    </div>
                    <textarea name="json" class="form-control cms-mono" rows="3" placeholder='{ "Common.Save": "Kaydet" }'></textarea>
                    <div class="cms-hint">@L["Translation.ImportHint"]</div>
                </form>
            </div>
        </div>
    </div>
</div>

<div class="cms-table-wrapper">
    <div class="cms-table-toolbar">
        <form method="get" asp-action="Index" class="d-flex gap-2">
            <input type="search" name="q" value="@Model.Search" class="form-control cms-search" placeholder="@L["Translation.SearchKey"]" />
            <button type="submit" class="btn btn-outline-secondary">@L["Common.Filter"]</button>
            @if (!string.IsNullOrWhiteSpace(Model.Search))
            {
                <a class="btn btn-link" asp-action="Index">@L["Common.Clear"]</a>
            }
        </form>
        <span class="text-muted small">@Model.Total</span>
    </div>
    <div class="table-responsive">
        <table class="table cms-table">
            <thead>
                <tr>
                    <th>@L["Translation.Key"]</th>
                    @foreach (var c in active)
                    {
                        <th>@c.Code.ToUpper()</th>
                    }
                    <th style="width:1%"></th>
                </tr>
            </thead>
            <tbody>
            @foreach (var k in Model.Keys)
            {
                <tr>
                    <td><span class="cms-mono small">@k.Key</span></td>
                    @foreach (var c in active)
                    {
                        var val = k.Values.TryGetValue(c.Code, out var v) ? v : null;
                        <td>
                            @if (string.IsNullOrEmpty(val))
                            {
                                <span class="text-danger small">—</span>
                            }
                            else
                            {
                                <span class="small text-truncate d-inline-block" style="max-width:280px" title="@val">@val</span>
                            }
                        </td>
                    }
                    <td>
                        <a class="cms-action-btn" title="@L["Common.Edit"]" asp-action="Edit" asp-route-key="@k.Key">
                            <i class="bi bi-pencil"></i>
                        </a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index" asp-route-q="@Model.Search" asp-route-page="@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}
