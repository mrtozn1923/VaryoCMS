@model SystemLoginViewModel
@{
    ViewData["Title"] = L["SystemAccount.SignIn"].Value;
    Layout = "_AuthLayout";
}

<div class="cms-auth-shell">
    <div class="cms-auth-card">
        <div class="cms-auth-brand">
            <div class="cms-brand-icon">✦</div>
            <span>Varyo CMS</span>
        </div>
        <h1 class="cms-section-title mb-1">@L["SystemAccount.Console"]</h1>
        <p class="cms-hint mb-3">@L["SystemAccount.ConsoleHint"]</p>

        @if (TempData["LoginError"] is string loginError)
        {
            <div class="cms-alert-danger mb-3">@loginError</div>
        }

        <form method="post" asp-action="Login">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="ReturnUrl" />
            <div asp-validation-summary="All" class="cms-alert-danger mb-3"></div>

            <div class="cms-form-group">
                <label asp-for="Email" class="cms-label">@L["Common.Email"]</label>
                <input asp-for="Email" class="form-control" autocomplete="username" autofocus />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="cms-form-group">
                <label asp-for="Password" class="cms-label">@L["Common.Password"]</label>
                <input asp-for="Password" class="form-control" autocomplete="current-password" />
                <span asp-validation-for="Password" class="text-danger small"></span>
            </div>

            <div class="form-check mb-3">
                <input asp-for="RememberMe" class="form-check-input" />
                <label asp-for="RememberMe" class="form-check-label">@L["Account.RememberMe"]</label>
            </div>

            <button type="submit" class="btn cms-btn-primary w-100">
                <i class="bi bi-box-arrow-in-right me-1"></i> @L["Account.SignIn"]
            </button>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
