@model TenantListViewModel
@{
    ViewData["Title"] = L["Tenant.Tenants"].Value;
}

@section PageActions {
    <a class="btn cms-btn-primary" asp-action="Create">
        <i class="bi bi-plus-lg me-1"></i> @L["Tenant.New"]
    </a>
}

@if (Model.Items.Count == 0)
{
    <div class="cms-empty-state">
        <i class="bi bi-buildings cms-empty-icon"></i>
        <h5>@L["Tenant.EmptyTitle"]</h5>
        <a class="btn cms-btn-primary" asp-action="Create"><i class="bi bi-plus-lg me-1"></i> @L["Tenant.New"]</a>
    </div>
}
else
{
    <div class="cms-table-wrapper">
        <div class="table-responsive">
            <table class="table cms-table">
                <thead>
                    <tr>
                        <th>@L["Tenant.Tenant"]</th>
                        <th class="text-center" style="width:90px">@L["Common.Users"]</th>
                        <th class="text-center" style="width:120px">@L["Common.ContentTypes"]</th>
                        <th style="width:110px">@L["Common.Status"]</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var t in Model.Items)
                {
                    <tr>
                        <td>
                            <span class="cms-table-title">@t.Name</span>
                            <span class="cms-table-meta">@t.Slug</span>
                        </td>
                        <td class="text-center">@t.UserCount</td>
                        <td class="text-center">@t.ContentTypeCount</td>
                        <td>
                            @if (t.IsActive)
                            {
                                <span class="badge cms-badge-success">@L["Common.Active"]</span>
                            }
                            else
                            {
                                <span class="badge cms-badge-secondary">@L["Common.Inactive"]</span>
                            }
                        </td>
                        <td>
                            <div class="cms-row-actions">
                                <a class="cms-action-btn" title="@L["Common.Edit"]" asp-action="Edit" asp-route-id="@t.Id">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a class="cms-action-btn" title="E-posta Ayarları"
                                   asp-controller="SystemTenantEmail" asp-action="Index" asp-route-tenantId="@t.Id">
                                    <i class="bi bi-envelope-gear"></i>
                                </a>
                                <form method="post" asp-action="Delete" asp-route-id="@t.Id"
                                      onsubmit="return confirm('@L["Tenant.DeleteConfirm", t.Name]');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="cms-action-btn cms-action-danger" title="@L["Common.Delete"]">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}
