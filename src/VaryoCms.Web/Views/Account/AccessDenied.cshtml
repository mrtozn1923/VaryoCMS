@{
    ViewData["Title"] = L["Account.AccessDenied"].Value;
}

<div class="cms-empty-state">
    <i class="bi bi-shield-lock cms-empty-icon"></i>
    <h5>@L["Account.NoAccessTitle"]</h5>
    <p class="text-muted">@L["Account.NoAccessText"]</p>
    <a class="btn cms-btn-primary" asp-controller="Home" asp-action="Index">
        <i class="bi bi-house me-1"></i> @L["Common.BackToHome"]
    </a>
</div>
