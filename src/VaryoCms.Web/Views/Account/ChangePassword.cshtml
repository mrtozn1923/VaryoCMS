@model ChangePasswordViewModel
@{
    ViewData["Title"] = L["Account.ChangePassword"].Value;
}

<div class="row justify-content-center">
    <div class="col-lg-6">
        @if (TempData["PasswordChanged"] is true)
        {
            <div class="cms-alert-success mb-3">
                <i class="bi bi-check-circle-fill"></i>
                <span>@L["Account.PasswordChanged"]</span>
            </div>
        }

        <div class="card cms-card">
            <div class="card-body">
                <form method="post" asp-action="ChangePassword">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="cms-alert-danger mb-3"></div>

                    <div class="cms-form-group">
                        <label asp-for="CurrentPassword" class="cms-label">@L["Field.CurrentPassword"]</label>
                        <input asp-for="CurrentPassword" class="form-control" autocomplete="current-password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>
                    <div class="cms-form-group">
                        <label asp-for="NewPassword" class="cms-label">@L["Field.NewPassword"]</label>
                        <input asp-for="NewPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>
                    <div class="cms-form-group">
                        <label asp-for="ConfirmPassword" class="cms-label">@L["Field.ConfirmPassword"]</label>
                        <input asp-for="ConfirmPassword" class="form-control" autocomplete="new-password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="cms-form-footer">
                        <button type="submit" class="btn cms-btn-primary">
                            <i class="bi bi-key me-1"></i> @L["Account.ChangePassword"]
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
