@model DictionaryEntryFormViewModel
@{
    ViewData["Title"] = L["Dictionary.EditTitle"].Value;
}

@section Breadcrumb {
    <a asp-action="Index">@L["Dictionary.Title"]</a> <i class="bi bi-chevron-right" style="font-size:.65rem"></i> @L["Common.Edit"]
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card cms-card">
            <div class="card-body">
                <form method="post" asp-action="Edit" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <partial name="_EntryFormBody" model="Model" />
                    <div class="cms-form-footer">
                        <a class="btn btn-outline-secondary" asp-action="Index">@L["Common.Cancel"]</a>
                        <button type="submit" class="btn cms-btn-primary">@L["Common.Save"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
