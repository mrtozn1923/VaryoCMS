@model DictionaryListViewModel
@{
    ViewData["Title"] = L["Dictionary.Title"].Value;
    var hasFilter = !string.IsNullOrWhiteSpace(Model.Search) || !string.IsNullOrWhiteSpace(Model.Category);
}

@section PageActions {
    <a class="btn cms-btn-primary" asp-action="Create">
        <i class="bi bi-plus-lg me-1"></i> @L["Dictionary.NewKey"]
    </a>
}

<div class="cms-table-wrapper">
    <div class="cms-table-toolbar">
        <form method="get" asp-action="Index">
            <div class="input-group">
                <input type="search" name="q" value="@Model.Search" class="form-control" placeholder="@L["Dictionary.SearchKey"]" style="min-width:180px; max-width:280px" />
                <span class="input-group-text text-muted px-2"><i class="bi bi-slash-lg" style="font-size:.75rem"></i></span>
                <input type="text" name="category" value="@Model.Category" class="form-control" placeholder="@L["Dictionary.Category"]" style="max-width:160px" />
                <button type="submit" class="btn btn-outline-secondary">@L["Common.Filter"]</button>
                @if (hasFilter)
                {
                    <a class="btn btn-outline-secondary" asp-action="Index">@L["Common.Clear"]</a>
                }
            </div>
        </form>
    </div>

    @if (Model.Items.Count == 0)
    {
        <div class="cms-empty-state border-0">
            <i class="bi bi-translate cms-empty-icon"></i>
            <h5>@L["Dictionary.EmptyTitle"]</h5>
            <p class="text-muted">@L["Dictionary.EmptyHint"]</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table cms-table">
                <thead>
                    <tr>
                        <th>@L["Dictionary.Key"]</th>
                        <th>@L["Dictionary.Category"]</th>
                        <th class="text-center" style="width:130px">@L["Dictionary.Translations"]</th>
                        <th style="width:170px">@L["Common.Updated"]</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    var complete = item.TranslatedCount >= Model.LanguageCount && Model.LanguageCount > 0;
                    <tr>
                        <td><span class="cms-mono">@item.KeyName</span></td>
                        <td>@(string.IsNullOrEmpty(item.Category) ? "—" : item.Category)</td>
                        <td class="text-center">
                            <span class="badge @(complete ? "cms-badge-success" : "cms-badge-secondary")">
                                @item.TranslatedCount / @Model.LanguageCount
                            </span>
                        </td>
                        <td class="text-muted small">@item.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <div class="cms-row-actions">
                                <a class="cms-action-btn" title="@L["Common.Edit"]" asp-action="Edit" asp-route-id="@item.Id">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" asp-action="Delete" asp-route-id="@item.Id"
                                      onsubmit="return confirm('@L["Dictionary.DeleteConfirm"]');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="cms-action-btn cms-action-danger" title="@L["Common.Delete"]">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

@if (Model.TotalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination">
            @for (int p = 1; p <= Model.TotalPages; p++)
            {
                <li class="page-item @(p == Model.Page ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-q="@Model.Search" asp-route-category="@Model.Category" asp-route-page="@p">@p</a>
                </li>
            }
        </ul>
    </nav>
}
