@model ApiCredentialFormViewModel
@{
    ViewData["Title"] = L["Api.NewCredential"].Value;
    ViewData["ApiActiveTab"] = "credentials";
}
@section Breadcrumb {
    <a asp-action="Index">@L["Api.Credentials"]</a>
    <i class="bi bi-chevron-right" style="font-size:.65rem"></i>
    @L["Api.NewCredential"]
}

<partial name="_ApiTabs" />

<div asp-validation-summary="All" class="cms-alert-danger mb-3"></div>

<div class="row g-4">
    <div class="col-lg-8">
        <form method="post" asp-action="Create">
            @Html.AntiForgeryToken()
            <partial name="_CredentialFormBody" model="Model" />
            <div class="cms-form-footer">
                <a class="btn btn-outline-secondary" asp-action="Index">@L["Common.Cancel"]</a>
                <button type="submit" class="btn cms-btn-primary">@L["Api.CreateCredential"]</button>
            </div>
        </form>
    </div>

    <div class="col-lg-4">
        <div class="card cms-card">
            <div class="card-body">
                <h6 class="fw-semibold mb-2"><i class="bi bi-info-circle me-1 text-info"></i>@L["Api.CredentialInfoTitle"]</h6>
                <p class="cms-hint">@L["Api.CredentialInfoBody"]</p>
                <p class="cms-hint mb-0"><i class="bi bi-eye-slash me-1"></i>@L["Api.KeyShownOnce"]</p>
            </div>
        </div>
    </div>
</div>
