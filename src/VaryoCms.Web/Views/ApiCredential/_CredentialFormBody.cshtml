@model ApiCredentialFormViewModel
@* Shared form body used by both Create and Edit. Must be inside <form>. *@

<div class="card cms-card mb-4">
    <div class="card-header cms-card-header"><h5 class="card-title mb-0">@L["Api.CredentialDetails"]</h5></div>
    <div class="card-body">
        <div class="cms-form-group">
            <label class="cms-label required" asp-for="Name">@L["Api.CredentialName"]</label>
            <input type="text" class="form-control" asp-for="Name"
                   placeholder="@L["Api.CredentialNamePlaceholder"]" autocomplete="off" />
            <span asp-validation-for="Name" class="text-danger cms-validation-msg"></span>
        </div>

        <div class="cms-form-group">
            <label class="cms-label" asp-for="AuthType">@L["Api.AuthTypeLabel"]</label>
            @if (Model.Id == 0)
            {
                @* New credential: auth type selectable *@
                <div class="d-flex gap-3">
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="AuthType"
                               id="authApiKey" value="ApiKey" />
                        <label class="form-check-label" for="authApiKey">
                            <i class="bi bi-key me-1"></i>API Key
                        </label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="AuthType"
                               id="authJwt" value="JWT" />
                        <label class="form-check-label" for="authJwt">
                            <i class="bi bi-shield-lock me-1"></i>JWT Bearer
                        </label>
                    </div>
                </div>
                <div class="cms-hint mt-1">@L["Api.AuthTypeHint"]</div>
            }
            else
            {
                @* Edit: auth type is immutable *@
                <input type="hidden" asp-for="AuthType" />
                <div class="fw-semibold">
                    @if (Model.AuthType == "ApiKey")
                    {
                        <i class="bi bi-key me-1 text-info"></i><span>API Key</span>
                    }
                    else
                    {
                        <i class="bi bi-shield-lock me-1 text-secondary"></i><span>JWT Bearer</span>
                    }
                    <span class="cms-hint ms-2">@L["Api.AuthTypeImmutable"]</span>
                </div>
            }
        </div>

        <div class="form-check form-switch">
            <input class="form-check-input" type="checkbox" asp-for="IsActive" />
            <label class="form-check-label" asp-for="IsActive">@L["Common.Active"]</label>
        </div>
    </div>
</div>

<div class="card cms-card mb-4">
    <div class="card-header cms-card-header d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">@L["Api.SelectContentTypes"]</h5>
        <button type="button" class="btn btn-sm btn-outline-secondary" id="toggleAllCt">
            @L["Api.SelectAll"]
        </button>
    </div>
    <div class="card-body p-0">
        @if (Model.ContentTypes.Count == 0)
        {
            <div class="p-3">
                <div class="cms-alert-info">
                    <i class="bi bi-info-circle-fill"></i>
                    <span>@L["Api.NoContentTypesAvailable"]</span>
                </div>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table cms-table mb-0">
                    <thead>
                        <tr>
                            <th style="width:48px" class="text-center">
                                <input type="checkbox" class="form-check-input" id="checkAll" />
                            </th>
                            <th>@L["Api.ContentType"]</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (int i = 0; i < Model.ContentTypes.Count; i++)
                    {
                        var ct = Model.ContentTypes[i];
                        <tr>
                            <td class="text-center">
                                <input type="hidden"   name="ContentTypes[@i].ContentTypeId" value="@ct.ContentTypeId" />
                                <input type="hidden"   name="ContentTypes[@i].Name"          value="@ct.Name" />
                                <input type="hidden"   name="ContentTypes[@i].Slug"          value="@ct.Slug" />
                                @* IsGranted: checkbox + hidden fallback *@
                                <input type="checkbox" class="form-check-input ct-check"
                                       name="ContentTypes[@i].IsGranted" value="true"
                                       @(ct.IsGranted ? "checked" : "") />
                                <input type="hidden"   name="ContentTypes[@i].IsGranted" value="false" />
                            </td>
                            <td>
                                <span class="cms-table-title">@ct.Name</span>
                                <span class="cms-table-meta">@ct.Slug</span>
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Toggle all checkboxes
        const checkAll = document.getElementById('checkAll');
        const ctChecks = () => document.querySelectorAll('.ct-check');
        if (checkAll) {
            checkAll.addEventListener('change', () =>
                ctChecks().forEach(c => c.checked = checkAll.checked));
            ctChecks().forEach(c => c.addEventListener('change', () =>
                checkAll.checked = [...ctChecks()].every(x => x.checked)));
            // Sync header on load
            checkAll.checked = [...ctChecks()].every(x => x.checked);
        }
    </script>
}
