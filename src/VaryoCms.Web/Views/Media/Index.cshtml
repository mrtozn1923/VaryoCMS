@using VaryoCms.Application.DTOs.Media
@model MediaLibraryViewModel
@{
    ViewData["Title"] = L["Media.Title"].Value;

    string FormatSize(long? bytes) => bytes switch
    {
        null or 0 => "",
        < 1024 => $"{bytes} B",
        < 1024 * 1024 => $"{bytes / 1024.0:0.#} KB",
        _ => $"{bytes / (1024.0 * 1024):0.##} MB"
    };
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.css" />

@if (TempData["MediaMsg"] is string mediaMsg)
{
    <div class="cms-alert-success mb-3"><i class="bi bi-check-circle-fill"></i><span>@mediaMsg</span></div>
}
@if (TempData["MediaErr"] is string mediaErr)
{
    <div class="cms-alert-warning mb-3"><i class="bi bi-exclamation-triangle-fill"></i><span>@mediaErr</span></div>
}

<div class="card cms-card mb-4">
    <div class="card-body">
        <form id="upload-form" method="post" asp-action="Upload" enctype="multipart/form-data" class="d-flex flex-wrap gap-2 align-items-end">
            @Html.AntiForgeryToken()
            <div class="flex-grow-1">
                <label for="file" class="cms-label">@L["Media.UploadFile"]</label>
                <input type="file" id="file" name="file" class="form-control"
                       accept="@MediaAllowedTypes.AcceptAttribute" required />
            </div>
            <button type="submit" id="upload-btn" class="btn cms-btn-primary flex-shrink-0">
                <i class="bi bi-upload me-1"></i> @L["Media.Upload"]
            </button>
        </form>
        <div id="upload-status"></div>
        <div class="cms-hint">@L["Media.UploadHint"]</div>
    </div>
</div>

<div class="d-flex gap-2 mb-3 flex-wrap align-items-center">
    <a class="btn btn-sm @(Model.MediaType == null ? "cms-btn-primary" : "btn-outline-secondary")"
       asp-action="Index" asp-route-page="1">@L["Media.Filter.All"]</a>
    <a class="btn btn-sm @(Model.MediaType == "image" ? "cms-btn-primary" : "btn-outline-secondary")"
       asp-action="Index" asp-route-type="image" asp-route-page="1">
        <i class="bi bi-image me-1"></i>@L["Media.Filter.Image"]
    </a>
    <a class="btn btn-sm @(Model.MediaType == "video" ? "cms-btn-primary" : "btn-outline-secondary")"
       asp-action="Index" asp-route-type="video" asp-route-page="1">
        <i class="bi bi-film me-1"></i>@L["Media.Filter.Video"]
    </a>
    <a class="btn btn-sm @(Model.MediaType == "audio" ? "cms-btn-primary" : "btn-outline-secondary")"
       asp-action="Index" asp-route-type="audio" asp-route-page="1">
        <i class="bi bi-music-note-beamed me-1"></i>@L["Media.Filter.Audio"]
    </a>
    <a class="btn btn-sm @(Model.MediaType == "file" ? "cms-btn-primary" : "btn-outline-secondary")"
       asp-action="Index" asp-route-type="file" asp-route-page="1">
        <i class="bi bi-file-earmark me-1"></i>@L["Media.Filter.File"]
    </a>
    <span class="ms-auto text-muted small">@Model.Total @L["Media.Files"]</span>
</div>

@if (Model.Items.Count == 0)
{
    <div class="cms-empty-state">
        <i class="bi bi-images cms-empty-icon"></i>
        <h5>@L["Media.EmptyTitle"]</h5>
        <p class="text-muted">@L["Media.EmptyHint"]</p>
    </div>
}
else
{
    <div class="cms-media-grid">
        @foreach (MediaAssetDto m in Model.Items)
        {
            string baseName = System.IO.Path.GetFileNameWithoutExtension(m.OriginalName);
            string ext = System.IO.Path.GetExtension(m.OriginalName);

            <div class="cms-media-card" id="media-card-@m.Id">
                @if (m.MediaType == "image")
                {
                    <img src="@m.Url" class="cms-media-thumb" alt="@m.AltText" loading="lazy" />
                }
                else
                {
                    <div class="cms-media-placeholder">
                        <i class="bi @(m.MediaType == "video" ? "bi-film" : m.MediaType == "audio" ? "bi-music-note-beamed" : "bi-file-earmark")"></i>
                    </div>
                }
                <div class="cms-media-body">
                    <div class="cms-media-name text-truncate" id="media-name-@m.Id" title="@m.OriginalName">@m.OriginalName</div>
                    <div class="cms-media-meta">
                        @if (m.FileSizeBytes.HasValue && m.FileSizeBytes > 0) { <span>@FormatSize(m.FileSizeBytes)</span> }
                        @if (m.Width.HasValue) { <span>· @m.Width×@m.Height</span> }
                        <span>· #@m.Id</span>
                    </div>
                    <div class="d-flex gap-1 mt-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary rename-btn"
                                data-id="@m.Id"
                                data-base="@baseName"
                                data-ext="@ext"
                                data-alt="@m.AltText"
                                data-type="@m.MediaType"
                                data-size="@FormatSize(m.FileSizeBytes)"
                                data-dims="@(m.Width.HasValue ? $"{m.Width}×{m.Height}" : "")"
                                data-date="@m.CreatedAt.ToString("yyyy-MM-dd")"
                                title="@L["Media.Rename"]">
                            <i class="bi bi-pencil"></i>
                        </button>
                        @if (m.MediaType == "image")
                        {
                            <button type="button" class="btn btn-sm btn-outline-secondary crop-btn"
                                    data-id="@m.Id" data-url="@m.Url" title="@L["Media.Crop"]">
                                <i class="bi bi-crop"></i>
                            </button>
                        }
                        <form method="post" asp-action="Delete" asp-route-id="@m.Id"
                              onsubmit="return confirm('@L["Media.DeleteConfirm"]');" class="flex-fill">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger w-100" title="@L["Common.Delete"]">
                                <i class="bi bi-trash"></i>
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-3">
            <ul class="pagination">
                @for (int p = 1; p <= Model.TotalPages; p++)
                {
                    <li class="page-item @(p == Model.Page ? "active" : "")">
                        <a class="page-link" asp-action="Index" asp-route-type="@Model.MediaType" asp-route-page="@p">@p</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@* Rename / Details modal *@
<div class="modal fade" id="renameModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>@L["Media.Rename"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div id="rename-error" class="cms-alert-warning mb-3 d-none"></div>
                <div class="mb-3">
                    <label class="cms-label">@L["Media.DisplayName"]</label>
                    <div class="input-group">
                        <input type="text" id="rename-base" class="form-control" autocomplete="off" />
                        <span class="input-group-text text-muted fw-medium" id="rename-ext"></span>
                    </div>
                </div>
                <div class="mb-3" id="rename-alt-row">
                    <label class="cms-label">@L["Media.AltText"]</label>
                    <input type="text" id="rename-alt" class="form-control" />
                </div>
                <div class="border rounded p-2 bg-light">
                    <table class="table table-sm table-borderless text-muted mb-0 small">
                        <tbody>
                            <tr><td class="py-1">@L["Media.FileType"]</td><td id="rename-info-type" class="fw-medium"></td></tr>
                            <tr><td class="py-1">@L["Media.FileSize"]</td><td id="rename-info-size"></td></tr>
                            <tr id="rename-dims-row"><td class="py-1">@L["Media.Dimensions"]</td><td id="rename-info-dims"></td></tr>
                            <tr><td class="py-1">@L["Media.UploadedAt"]</td><td id="rename-info-date"></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@L["Common.Cancel"]</button>
                <button type="button" id="rename-save-btn" class="btn cms-btn-primary">
                    <i class="bi bi-check-lg me-1"></i>@L["Common.Save"]
                </button>
            </div>
        </div>
    </div>
</div>

@* Crop modal *@
<div class="modal fade" id="cropModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">@L["Media.Crop"]</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div style="max-height:60vh;">
                    <img id="cropImage" src="" style="max-width:100%;" alt="" />
                </div>
            </div>
            <div class="modal-footer">
                <form method="post" id="cropForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="x" id="cropX" />
                    <input type="hidden" name="y" id="cropY" />
                    <input type="hidden" name="width" id="cropW" />
                    <input type="hidden" name="height" id="cropH" />
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">@L["Common.Cancel"]</button>
                    <button type="submit" class="btn cms-btn-primary">@L["Media.ApplyCrop"]</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/cropperjs/1.6.1/cropper.min.js"></script>
    <script src="~/js/media-editor.js" asp-append-version="true"></script>
    <script>
    // XSS-safe helper: renders an error alert using DOM methods so user-supplied text is never injected as HTML.
    function showUploadError(container, message) {
        container.innerHTML = '';
        var div  = document.createElement('div');
        div.className = 'cms-alert-warning mt-2';
        var icon = document.createElement('i');
        icon.className = 'bi bi-exclamation-triangle-fill me-1';
        var txt = document.createTextNode(message);
        div.appendChild(icon);
        div.appendChild(txt);
        container.appendChild(div);
    }
    (function () {
        var form   = document.getElementById('upload-form');
        var btn    = document.getElementById('upload-btn');
        var status = document.getElementById('upload-status');

        form.addEventListener('submit', async function (e) {
            e.preventDefault();
            var originalHtml = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>';
            status.innerHTML = '';
            try {
                var resp = await fetch(form.action, { method: 'POST', body: new FormData(form) });
                var data = await resp.json();
                if (resp.ok && data && data.id) {
                    window.location.reload();
                } else {
                    var fallback = @Json.Serialize(L["Err.UploadFailed"].Value);
                    var msg = typeof data === 'string' ? data : fallback;
                    showUploadError(status, msg);
                    btn.disabled = false; btn.innerHTML = originalHtml;
                }
            } catch (_) {
                showUploadError(status, @Json.Serialize(L["Err.ConnectionError"].Value));
                btn.disabled = false; btn.innerHTML = originalHtml;
            }
        });
    })();
    </script>
}
