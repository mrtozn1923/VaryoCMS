@model ContentFieldFormViewModel
@{
    ViewData["Title"] = L["ContentField.Edit"].Value;
}

@section Breadcrumb {
    <a asp-controller="ContentType" asp-action="Index">@L["ContentType.Breadcrumb"]</a>
    <i class="bi bi-chevron-right" style="font-size:.65rem"></i>
    <a asp-controller="ContentField" asp-action="Index" asp-route-contentTypeId="@Model.ContentTypeId">@L["ContentField.Title"]</a>
    <i class="bi bi-chevron-right" style="font-size:.65rem"></i> @L["Common.Edit"]
}

<div class="row justify-content-center">
    <div class="col-lg-7">
        <div class="card cms-card">
            <div class="card-body">
                <form method="post" asp-controller="ContentField" asp-action="Edit"
                      asp-route-contentTypeId="@Model.ContentTypeId" asp-route-id="@Model.Id">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="ContentTypeId" />
                    <partial name="_FieldFormFields" model="Model" />
                    <div class="cms-form-footer">
                        <a class="btn btn-outline-secondary"
                           asp-controller="ContentField" asp-action="Index" asp-route-contentTypeId="@Model.ContentTypeId">@L["Common.Cancel"]</a>
                        <button type="submit" class="btn cms-btn-primary">@L["Common.SaveChanges"]</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<partial name="_FieldOptionsModal" />

@section Scripts {
    <script src="~/js/field-options.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}
