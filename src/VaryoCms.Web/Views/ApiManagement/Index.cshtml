@model IReadOnlyList<ApiConfigListItemDto>
@inject VaryoCms.Application.Interfaces.ITenantContext TenantCtx
@{
    ViewData["Title"] = L["Api.Title"].Value;
    ViewData["ApiActiveTab"] = "content-types";
}

<partial name="_ApiTabs" />

@if (Model.Count == 0)
{
    <div class="cms-empty-state">
        <i class="bi bi-code-slash cms-empty-icon"></i>
        <h5>@L["Api.EmptyTitle"]</h5>
        <p class="text-muted">@L["Api.EmptyHint"]</p>
    </div>
}
else
{
    <div class="cms-table-wrapper">
        <div class="table-responsive">
            <table class="table cms-table">
                <thead>
                    <tr>
                        <th>@L["Api.ContentType"]</th>
                        <th style="width:120px">@L["Api.Api"]</th>
                        <th style="width:130px">@L["Api.Access"]</th>
                        <th style="width:1%"></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <span class="cms-table-title">@item.ContentTypeName</span>
                            <span class="cms-table-meta">@item.ContentTypeSlug</span>
                        </td>
                        <td>
                            @if (!item.IsConfigured)
                            {
                                <span class="badge cms-badge-secondary">@L["Api.NotConfigured"]</span>
                            }
                            else if (item.IsEnabled)
                            {
                                <span class="badge cms-badge-success">@L["Api.Enabled"]</span>
                            }
                            else
                            {
                                <span class="badge cms-badge-secondary">@L["Api.Disabled"]</span>
                            }
                        </td>
                        <td>
                            @if (!item.IsConfigured)
                            {
                                <span class="text-muted">—</span>
                            }
                            else if (item.IsPublic)
                            {
                                <span class="badge cms-badge-info"><i class="bi bi-unlock me-1"></i>@L["Api.Public"]</span>
                            }
                            else
                            {
                                <span class="badge cms-badge-warning"><i class="bi bi-lock me-1"></i>@L["Api.Protected"]</span>
                            }
                        </td>
                        <td>
                            <div class="cms-row-actions">
                                @if (item.IsEnabled)
                                {
                                    <a class="cms-action-btn" href="/api/docs/@TenantCtx.TenantSlug"
                                       target="_blank" title="@L["Api.ViewDocs"]">
                                        <i class="bi bi-book"></i>
                                    </a>
                                }
                                <a class="cms-action-btn" asp-action="Configure"
                                   asp-route-contentTypeId="@item.ContentTypeId" title="@L["Api.Configure"]">
                                    <i class="bi bi-gear"></i>
                                </a>
                            </div>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    </div>
}
