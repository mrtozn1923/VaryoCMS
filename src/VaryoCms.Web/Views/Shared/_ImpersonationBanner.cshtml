@inject VaryoCms.Application.Interfaces.ITenantContext TenantContext
@{
    // Shown only while a SystemAdmin is impersonating a tenant (the resolved context is the target tenant).
}
<div class="cms-impersonation-banner">
    <span>
        <i class="bi bi-incognito me-1"></i>
        @L["Impersonation.Banner"] <strong class="cms-mono">@TenantContext.TenantSlug</strong>
    </span>
    <form method="post" asp-controller="Impersonation" asp-action="Exit" class="d-inline">
        @Html.AntiForgeryToken()
        <button type="submit" class="btn btn-sm btn-light">@L["Impersonation.Exit"]</button>
    </form>
</div>
