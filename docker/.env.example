# Copy this file to docker/.env and fill in the values before running docker-compose.
# The .env file is gitignored — never commit real secrets.

# SQL Server SA password (used in the connection string passed to the web container).
DB_PASSWORD=change_me_strong_password_here

# JWT token signing key — must be at least 32 characters.
JWT_SIGNING_KEY=change_me_to_a_random_32_plus_char_secret

# Optional: override the JWT issuer label (default: VaryoCms).
# JWT_ISSUER=VaryoCms
